# Synthetic mix micro-benchmark (.nrl v0). Not AES-256; exercises a fixed XOR/rotate
# ladder and prints FNV-1a over a 32-byte state. For digest lock, use aes256_locked.nrl
# (requires nrl with expected_fnv1a64 parsing).

mode=bench
profile=aes256-synth
neurons=4096
iterations=64
reps=1
threshold=6
